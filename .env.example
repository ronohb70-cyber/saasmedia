# ==========================================
# Social SaaS — Environment Variables
# Copy this file to .env and fill in values
# ==========================================

# ── Database ──────────────────────────────
# PostgreSQL connection string
# Use docker-compose for local dev (see docker-compose.yml)
DATABASE_URL="postgresql://social:password123@localhost:5432/social_saas?schema=public"

# ── Redis (BullMQ Worker Queues) ──────────
REDIS_HOST="localhost"
REDIS_PORT="6379"

# ── API Server ────────────────────────────
PORT=3001
FRONTEND_URL="http://localhost:3000"

# ── JWT Authentication ────────────────────
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET="CHANGE_ME_IN_PRODUCTION"

# ── Stripe Billing ────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── AI (Post Enhancement) ─────────────────
OPENAI_API_KEY="sk-..."

# ── Next.js Frontend ──────────────────────
# URL of the NestJS API (used by Next.js server-side)
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# ── OAuth — Facebook / Instagram ─────────
# https://developers.facebook.com/apps/
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
INSTAGRAM_CLIENT_ID=""
INSTAGRAM_CLIENT_SECRET=""

# ── OAuth — X (Twitter) ───────────────────
# https://developer.twitter.com/en/portal/
X_CLIENT_ID=""
X_CLIENT_SECRET=""

# ── OAuth — LinkedIn ──────────────────────
# https://www.linkedin.com/developers/apps/
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# ── OAuth — TikTok ───────────────────────
# https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
